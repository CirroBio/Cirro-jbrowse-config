params {
    // Cirro project and dataset containing the input genome files
    project_id        = null

    // Cirro dataset ID containing the input genome files
    dataset_id        = null

    // Reference assembly name (e.g. hg38, mm10)
    assembly          = "hg38"

    // List of track spec strings in "TYPE:NAME:FILE_PATH[:INDEX_PATH]" format.
    // Supported types: bam, cram, bigwig, vcf, gff
    // Example: ["bam:Sample1:alignments/sample1.bam", "bigwig:Coverage:coverage/sample1.bw"]
    tracks            = []

    // Optional reference FASTA in "PROJ_ID:DS_ID:FILE_PATH" format.
    // When null, no --fasta flag is passed to the select command.
    fasta             = null

    // Cirro project ID to upload the generated JBrowse2 dataset into
    upload_project_id = null

    // Name for the uploaded Cirro dataset
    dataset_name      = "JBrowse Config"

    // Description for the uploaded Cirro dataset
    description       = "Generated by cirro-jbrowse-config Nextflow workflow"

    // Local output directory for generated static site assets
    output_dir        = "jbrowse-site"
}

process {
    container    = 'ghcr.io/astral-sh/uv:python3.12-bookworm-slim'
    beforeScript = 'uv pip install --system git+https://github.com/CirroBio/Cirro-jbrowse-config.git'
    errorStrategy = 'finish'
}
