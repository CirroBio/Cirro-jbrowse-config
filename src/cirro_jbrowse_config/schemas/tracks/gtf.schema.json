{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Resolved GTF Track Spec",
  "description": "A bgzipped GTF track spec with all file references resolved to URLs",
  "type": "object",
  "required": ["name", "gtf_gz_url", "tbi_url", "sequence_adapter"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string" },
    "gtf_gz_url": { "type": "string", "format": "uri" },
    "tbi_url": { "type": "string", "format": "uri" },
    "sequence_adapter": {
      "type": "object",
      "required": ["fasta_url", "fai_url"],
      "additionalProperties": false,
      "properties": {
        "fasta_url": { "type": "string", "format": "uri" },
        "fai_url": { "type": "string", "format": "uri" },
        "gzi_url": { "type": "string", "format": "uri" }
      }
    },
    "category": { "type": "array", "items": { "type": "string" } }
  }
}
