<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>JBrowse2 Genome Browser</title>
  <style>
    html, body { margin: 0; padding: 0; height: 100%; }
    #root { height: 100vh; }
  </style>
</head>
<body>
  <div id="root"></div>
  <!-- The JBrowse2 UMD bundle is self-contained: it bundles its own React 18.
       Do NOT load React/ReactDOM from CDN — a second copy causes hook dispatcher conflicts. -->
  <script src="./react-linear-genome-view.umd.production.min.js"></script>
  <script>
    const { createViewState, JBrowseLinearGenomeView, React, createRoot } = JBrowseReactLinearGenomeView;

    function getUrlLocation() {
      return new URLSearchParams(window.location.search).get('loc') || undefined;
    }

    function startLocationSync(state) {
      let lastLoc = null;
      setInterval(() => {
        try {
          const view = state.session.view;
          const blocks = view.dynamicBlocks?.contentBlocks;
          if (!blocks?.length) return;
          const refName = blocks[0].refName;
          const rawStart = blocks[0].start;
          const rawEnd = blocks[blocks.length - 1].end;
          // When zoom is animating, bpPerPx hasn't committed yet but scaleFactor
          // reflects the CSS zoom applied to the rendered tracks. Adjust the range
          // so the URL stays in sync with what the user actually sees.
          const sf = view.scaleFactor;
          let start, end;
          if (sf && Math.abs(sf - 1) > 0.01) {
            const center = (rawStart + rawEnd) / 2;
            const halfBp = (rawEnd - rawStart) / 2 / sf;
            start = Math.round(center - halfBp) + 1;
            end = Math.round(center + halfBp);
          } else {
            start = Math.round(rawStart) + 1;
            end = Math.round(rawEnd);
          }
          const loc = `${refName}:${start}..${end}`;
          if (loc === lastLoc) return;
          lastLoc = loc;
          const params = new URLSearchParams(window.location.search);
          params.set('loc', loc);
          history.replaceState(null, '', '?' + params.toString());
        } catch (_) {}
      }, 400);
    }

    fetch("{{ config_json_path }}")
      .then(r => r.json())
      .then(config => {
        const state = createViewState({
          assembly: config.assemblies[0],
          tracks: config.tracks,
          configuration: config.configuration || {},
          location: getUrlLocation() || config.defaultLocation || undefined,
        });

        // Activate all configured tracks using the embedded component API.
        // Passing defaultSession with full JBrowse2 session format causes
        // "ViewType undefined" errors in the react-linear-genome-view2 bundle.
        if (config.tracks && config.tracks.length > 0) {
          config.tracks.forEach(t => {
            try { state.session.view.showTrack(t.trackId); } catch (_) {}
          });
        }

        startLocationSync(state);
        const root = createRoot(document.getElementById("root"));
        root.render(React.createElement(JBrowseLinearGenomeView, { viewState: state }));
      })
      .catch(err => {
        document.getElementById("root").innerHTML =
          `<pre style="color:red;padding:1em">Failed to load config.json:\n${err}</pre>`;
      });
  </script>
</body>
</html>
